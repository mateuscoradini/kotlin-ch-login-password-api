              "const body = pm.response.json();",
              "pm.test('valid is false', () => pm.expect(body.valid).to.eql(false));",
              "['MIN_LENGTH','NO_DIGIT','NO_UPPERCASE','NO_SPECIAL_CHARACTER'].forEach(code =>",
