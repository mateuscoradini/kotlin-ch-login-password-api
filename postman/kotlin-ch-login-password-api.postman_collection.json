{
  "info": {
    "_postman_id": "5e1c8a30-7b2e-4f10-8fcd-passwordvalidator",
    "name": "Password Validator API",
    "description": "Smoke tests automatizados para o endpoint POST /api/v1/passwords/validate. Cobre os 8 exemplos canônicos do README-INSTRUCTIONS.md, dois cenários de erro 400 e o /actuator/health. Use com os environments local/test/staging/prod em postman/env/.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "valid - canonical example AbTp9!fok",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/passwords/validate", "host": ["{{baseUrl}}"], "path": ["api", "v1", "passwords", "validate"] },
        "body": { "mode": "raw", "raw": "{\"password\":\"AbTp9!fok\"}" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('valid is true', () => pm.expect(body.valid).to.eql(true));",
              "pm.test('violations is empty', () => pm.expect(body.violations).to.eql([]));"
            ]
          }
        }
      ]
    },
    {
      "name": "invalid - empty password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/passwords/validate", "host": ["{{baseUrl}}"], "path": ["api", "v1", "passwords", "validate"] },
        "body": { "mode": "raw", "raw": "{\"password\":\"\"}" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('valid is false', () => pm.expect(body.valid).to.eql(false));",
              "pm.test('violations contains MIN_LENGTH', () => pm.expect(body.violations).to.include('MIN_LENGTH'));"
            ]
          }
        }
      ]
    },
